# ============================================================
# MiDoc - consultorio-app
# Copia este archivo como `.env` y ajusta valores reales.
# ============================================================

# Runtime
NODE_ENV="development"
APP_BASE_URL="http://localhost:3000"

# Base de datos / auth
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/consultorio?schema=public"
# Base dedicada para tests de integración. Debe contener "test" en el nombre.
# Si no se define, el suite de DB se salta automáticamente.
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/consultorio_test?schema=public"
NEXTAUTH_SECRET="replace_with_strong_random_secret_min_32_chars"
QUESTIONNAIRE_TOKEN_SECRET="replace_with_another_strong_secret_min_32_chars"

# Legal / versionado
TERMS_VERSION="v1"
PRIVACY_VERSION="v1"

# Feature flags
# Habilita historia clínica completa (ClinicalHistory + EncounterHistory).
# Valores: "true" | "false". Default: "false".
CLINICAL_HISTORY_ENABLED="false"
# Habilita el "modo consulta" unificado (beta) en /medico/citas/[id]/consulta-v2.
# Requiere además CLINICAL_HISTORY_ENABLED=true.
CONSULTA_UNIFIED_ENABLED="false"

# WhatsApp / procesos internos
# Debe coincidir con APP_WEBHOOK_SECRET del whatsapp-bot
WHATSAPP_WEBHOOK_SECRET="replace_with_whatsapp_webhook_secret"
NOTIFICATION_CRON_SECRET="replace_with_cron_secret"
WHATSAPP_API_URL="http://localhost:3001/api/whatsapp/send"

# OpenAI (opcional si usaras modulos IA)
OPENAI_API_KEY=""

# Notificaciones (defaults recomendados)
NOTIFICATION_REMINDER_LEAD_MINUTES="60"
NOTIFICATION_REMINDER_LEAD_HOURS="24,3,1"
NOTIFICATION_REMINDER_WINDOW_MINUTES="15"
NOTIFICATION_MAX_RETRY_ATTEMPTS="3"
NOTIFICATION_RETRY_WINDOW_HOURS="24"
NOTIFICATION_PENDING_ESCALATION_MINUTES="120"
NOTIFICATION_PENDING_OVERDUE_MINUTES="0"
NOTIFICATION_PENDING_AUTO_CLOSE_HOURS="24"

# Cloudinary (opcional; valores publicos)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# Billing / pagos
PAYMENTS_PROVIDER="MOCK"
PAYMENTS_WEBHOOK_SECRET="replace_with_payments_webhook_secret"
