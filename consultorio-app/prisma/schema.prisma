model AIInsight {
  id            String @id @default(cuid())
  appointmentId String @unique
  doctorId      String

  diagnoses      Json? // Array of { diagnosis, reasoning }
  treatments     Json? // Array of { treatment, instructions }
  allowedFoods   Json? // Array of strings
  forbiddenFoods Json? // Array of strings

  medicationContext String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model AIProcessingJob {
  id            String      @id @default(cuid())
  appointmentId String
  doctorId      String
  kind          AIJobKind
  status        AIJobStatus @default(QUEUED)
  progressPct   Int         @default(0)
  statusMessage String?
  resultPayload Json?
  errorMessage  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  finishedAt    DateTime?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor      User        @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([appointmentId, kind, createdAt])
  @@index([doctorId, createdAt])
  @@index([status, createdAt])
}

model SecurityIncident {
  id                  String                  @id @default(cuid())
  reportedByUserId    String
  assignedToUserId    String?
  severity            IncidentSeverity
  category            IncidentCategory
  status              IncidentStatus          @default(OPEN)
  title               String
  summary             String
  detectedAt          DateTime
  containedAt         DateTime?
  resolvedAt          DateTime?
  affectedScope       Json?
  correctiveActions   String?
  rootCause           String?
  notificationRequired Boolean                @default(false)
  notifiedAt          DateTime?
  evidenceExportRef   String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  reportedBy User  @relation("IncidentReporter", fields: [reportedByUserId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("IncidentAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([status, detectedAt])
  @@index([severity, status])
  @@index([reportedByUserId, createdAt])
}

model PatientPreCheckin {
  id                        String   @id @default(cuid())
  patientId                 String
  appointmentId             String?
  doctorId                  String
  attendanceConfirmed       Boolean  @default(false)
  demographicsConfirmed     Boolean  @default(false)
  pendingPaymentsAcknowledged Boolean @default(false)
  checklist                 Json?
  notes                     String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  doctor      User         @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@index([appointmentId, createdAt])
  @@index([doctorId, createdAt])
}

model PatientDocument {
  id            String                @id @default(cuid())
  patientId     String
  appointmentId String?
  doctorId      String
  category      PatientDocumentCategory
  fileName      String
  fileUrl       String
  mimeType      String?
  sizeBytes     Int?
  status        PatientDocumentStatus @default(ACTIVE)
  uploadedAt    DateTime              @default(now())
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  doctor      User         @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId, uploadedAt])
  @@index([appointmentId, uploadedAt])
  @@index([doctorId, uploadedAt])
}

model DigitalConsent {
  id            String            @id @default(cuid())
  patientId     String
  appointmentId String?
  doctorId      String
  consentType   DigitalConsentType
  version       String
  acceptedAt    DateTime
  actorType     ConsentActorType  @default(PATIENT)
  source        AuditSource       @default(PATIENT_PORTAL)
  ipAddress     String?
  userAgent     String?
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  doctor      User         @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId, consentType, acceptedAt])
  @@index([appointmentId, consentType, acceptedAt])
}

model ArcoRequest {
  id               String            @id @default(cuid())
  patientId        String
  clinicId         String?
  requestedByUserId String?
  resolvedByUserId String?
  type             ArcoRequestType
  status           ArcoRequestStatus @default(OPEN)
  requestText      String
  resolutionText   String?
  evidenceRef      String?
  requestedAt      DateTime          @default(now())
  resolvedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic      Clinic?  @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  requestedBy User?    @relation("ArcoRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  resolvedBy  User?    @relation("ArcoResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([patientId, status, requestedAt])
  @@index([clinicId, status, requestedAt])
}

model DataRetentionPolicy {
  id              String              @id @default(cuid())
  clinicId        String?
  scope           RetentionScope      @default(GLOBAL)
  dataCategory    RetentionDataCategory
  retentionDays   Int
  hardDelete      Boolean             @default(false)
  active          Boolean             @default(true)
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([scope, dataCategory, active])
  @@index([clinicId, dataCategory, active])
}

model DataDeletionLog {
  id                String           @id @default(cuid())
  patientId         String
  appointmentId     String?
  performedByUserId String?
  mode              DeletionMode
  reason            String
  metadata          Json?
  createdAt         DateTime         @default(now())

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  performedBy User?        @relation("DataDeletionPerformedBy", fields: [performedByUserId], references: [id], onDelete: SetNull)

  @@index([patientId, createdAt])
  @@index([appointmentId, createdAt])
}

