generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  role         UserRole @default(DOCTOR)
  active       Boolean  @default(true)
  bossId       String?

  // Public Profile Fields
  specialty           String?
  slug                String? @unique
  bio                 String?
  profileImage        String?
  professionalLicense String?
  clinicAddress       String?
  logoImage           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinicId String?

  manager               User?                 @relation("SecretaryManager", fields: [bossId], references: [id], onDelete: SetNull)
  managedUsers          User[]                @relation("SecretaryManager")
  doctorConfig          DoctorConfig?
  subscription          DoctorSubscription?
  onboarding            DoctorOnboarding?
  legalAcceptances      LegalAcceptance[]
  securityIncidents     SecurityIncident[] @relation("IncidentReporter")
  assignedIncidents     SecurityIncident[] @relation("IncidentAssignee")
  blocks                AvailabilityBlock[]
  schedules             ScheduleBlock[]
  appointments          Appointment[]
  clinicalNotes         ClinicalNote[]
  signedClinicalNotes   ClinicalNote[]        @relation("SignedClinicalNotes")
  whatsappMessages      WhatsAppMessageLog[]
  patientAccounts       Patient[]             @relation("PatientAccount")
  directoryPatients     Patient[]             @relation("DoctorPatientDirectory")
  appointmentAuditLogs  AppointmentAuditLog[]
  auditLogs             AuditLog[]            @relation("UserToAuditLogs")
  doctorConsentCaptures ConsentCapture[]      @relation("DoctorConsentCaptures")
  capturedConsentLogs   ConsentCapture[]      @relation("ConsentCapturedByUser")
  aiProcessingJobs      AIProcessingJob[]
  billingReceipts       BillingReceipt[]
  clinic               Clinic?                @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  ownedClinic          Clinic?                @relation("ClinicOwner")
  waitlistEntries      WaitlistEntry[]
  waitlistOffers       WaitlistOffer[]
  patientPreCheckins   PatientPreCheckin[]
  patientDocuments     PatientDocument[]
  digitalConsentLogs   DigitalConsent[]
  arcoRequests         ArcoRequest[]          @relation("ArcoRequestedBy")
  resolvedArcoRequests ArcoRequest[]          @relation("ArcoResolvedBy")
  deletionLogs         DataDeletionLog[]      @relation("DataDeletionPerformedBy")
  clinicalEncounters   ClinicalEncounter[]    @relation("EncounterDoctor")

  @@index([bossId])
  @@index([clinicId])
}

model DoctorSubscription {
  id                     String    @id @default(cuid())
  doctorId               String    @unique
  status                 String    @default("PENDING")
  provider               String    @default("MOCK")
  planName               String    @default("Plan Mensual")
  amount                 Decimal?  @db.Decimal(10, 2)
  currency               String    @default("MXN")
  customerId             String?
  externalSubscriptionId String?
  externalPriceId        String?
  paymentMethodLast4     String?
  cancelAtPeriodEnd      Boolean   @default(false)
  canceledAt             DateTime?
  lastPaymentAt          DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  features               Json      @default("{}")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([provider, externalSubscriptionId])
  @@index([status, currentPeriodEnd])
}

model DoctorOnboarding {
  id          String    @id @default(cuid())
  doctorId    String    @unique
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model LegalAcceptance {
  id                String   @id @default(cuid())
  userId            String
  termsVersion      String
  privacyVersion    String
  termsAcceptedAt   DateTime
  privacyAcceptedAt DateTime
  ipAddress         String?
  userAgent         String?
  context           String   @default("REGISTER")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PaymentWebhookEvent {
  id              String    @id @default(cuid())
  provider        String
  eventId         String
  eventType       String
  status          String    @default("RECEIVED")
  payload         Json
  processingError String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([provider, eventId])
  @@index([status, createdAt])
}

model DoctorConfig {
  id                                String           @id @default(cuid())
  doctorId                          String           @unique
  consultationDurationMin           Int
  extendedConsultationEnabled       Boolean          @default(true)
  whatsappConnected                 Boolean          @default(false)
  reminderLeadHours                 String?
  reminderWindowMinutes             Int?             @default(15)
  whatsappAutoReplyEnabled          Boolean          @default(true)
  whatsappAutoConfirmEnabled        Boolean          @default(true)
  whatsappAutoCancelEnabled         Boolean          @default(true)
  whatsappBookingMessageTemplate    String?
  whatsappQuestionnaireTemplate     String?
  whatsappReminderPendingTemplate   String?
  whatsappReminderConfirmedTemplate String?
  normalConsultationPrice           Decimal?         @db.Decimal(10, 2)
  extendedConsultationPrice         Decimal?         @db.Decimal(10, 2)
  depositEnabled                    Boolean          @default(false)
  depositAmount                     Decimal?         @db.Decimal(10, 2)
  depositExpiresInMinutes           Int              @default(30)
  cancellationWindowHours           Int              @default(24)
  cancellationRefundMode            DepositRefundMode @default(FULL)
  cancellationPartialRefundPct      Int              @default(50)
  receiptSeries                     String?
  issuerLegalName                   String?
  issuerTaxId                       String?
  issuerTaxRegime                   String?
  issuerFiscalZipCode               String?
  effectiveFrom                     DateTime?
  preferredConsultationMode         ConsultationMode @default(MANUAL)
  createdAt                         DateTime         @default(now())
  updatedAt                         DateTime         @updatedAt

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Patient {
  id               String         @id @default(cuid())
  userId           String?
  ownerDoctorId    String?
  clinicId         String?
  firstName        String
  lastNamePaternal String
  lastNameMaternal String?
  sex              PatientSex?
  gender           PatientGender?
  dateOfBirth      DateTime       @default(now())
  phone            String
  email            String?
  taxId            String?
  fiscalZipCode    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user                 User?                 @relation("PatientAccount", fields: [userId], references: [id], onDelete: SetNull)
  ownerDoctor          User?                 @relation("DoctorPatientDirectory", fields: [ownerDoctorId], references: [id], onDelete: Cascade)
  appointments         Appointment[]
  medicalRecord        MedicalRecord?
  clinicalHistory      ClinicalHistory?
  clinicalNotes        ClinicalNote[]
  whatsappMessages     WhatsAppMessageLog[]
  appointmentAuditLogs AppointmentAuditLog[]
  auditLogs            AuditLog[]
  consentCaptures      ConsentCapture[]
  contacts             PatientContact[]
  clinic               Clinic?                @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  waitlistEntries      WaitlistEntry[]
  waitlistOffers       WaitlistOffer[]
  preCheckins          PatientPreCheckin[]
  uploadedDocuments    PatientDocument[]
  digitalConsents      DigitalConsent[]
  arcoRequests         ArcoRequest[]
  deletionLogs         DataDeletionLog[]
  clinicalEncounters   ClinicalEncounter[]

  @@index([ownerDoctorId])
  @@index([ownerDoctorId, lastNamePaternal, firstName])
  @@index([clinicId])
}

model PatientContact {
  id               String          @id @default(cuid())
  patientId        String
  relation         PatientRelation
  firstName        String
  lastNamePaternal String
  lastNameMaternal String?
  phone            String
  email            String?
  isPrimary        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([patientId])
  @@index([patientId, isPrimary])
}

model AvailabilityBlock {
  id        String   @id @default(cuid())
  doctorId  String
  date      DateTime
  startTime DateTime
  endTime   DateTime
  isPublic  Boolean  @default(true)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model ScheduleBlock {
  id        String            @id @default(cuid())
  doctorId  String
  date      DateTime
  startTime DateTime
  endTime   DateTime
  reason    String?
  type      ScheduleBlockType
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Appointment {
  id                    String            @id @default(cuid())
  doctorId              String
  patientId             String
  clinicId              String?
  contactId             String?
  date                  DateTime
  startTime             DateTime
  endTime               DateTime
  appointmentType       AppointmentType
  durationMin           Int
  source                AppointmentSource
  status                AppointmentStatus @default(PENDING)
  notes                 String?
  questionnaireAnswered Boolean           @default(false)
  paymentStatus         AppointmentPaymentStatus @default(NOT_REQUIRED)
  depositRequiredAmount Decimal?          @db.Decimal(10, 2)
  depositPaidAmount     Decimal?          @db.Decimal(10, 2)
  depositDueAt          DateTime?
  depositPaidAt         DateTime?
  cancellationPolicySnapshot Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  doctor           User                  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient          Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  contact          PatientContact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  questionnaire    Questionnaire?
  notifications    Notification[]
  clinicalNote     ClinicalNote?
  encounterHistory EncounterHistory?
  aiInsight        AIInsight?
  whatsappMessages WhatsAppMessageLog[]
  auditLogs        AppointmentAuditLog[]
  systemAuditLogs  AuditLog[]
  consentCaptures  ConsentCapture[]
  aiProcessingJobs AIProcessingJob[]
  billingReceipt   BillingReceipt?
  clinic           Clinic?                 @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  waitlistOffers   WaitlistOffer[]         @relation("SourceAppointmentWaitlistOffers")
  preCheckins      PatientPreCheckin[]
  documents        PatientDocument[]
  digitalConsents  DigitalConsent[]
  deletionLogs     DataDeletionLog[]
  clinicalEncounters ClinicalEncounter[]

  @@index([clinicId])
  @@index([doctorId, date])
  @@index([doctorId, startTime])
  @@index([patientId, date])
  @@index([status, date])
}

model BillingReceipt {
  id            String      @id @default(cuid())
  doctorId      String
  appointmentId String      @unique
  series        String
  folioNumber   Int
  issuedAt      DateTime
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  doctor      User        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([doctorId, series, folioNumber])
  @@index([doctorId, issuedAt])
}

model Clinic {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String?  @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner        User?         @relation("ClinicOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  users        User[]
  patients     Patient[]
  appointments Appointment[]
  waitlistEntries WaitlistEntry[]
  waitlistOffers  WaitlistOffer[]
  arcoRequests    ArcoRequest[]
  retentionPolicies DataRetentionPolicy[]
}

model WaitlistEntry {
  id                    String              @id @default(cuid())
  doctorId              String
  clinicId              String?
  patientId             String
  appointmentType       AppointmentType?
  preferredWeekdays     Json?
  preferredStartMinute  Int?
  preferredEndMinute    Int?
  priority              Int                 @default(100)
  status                WaitlistEntryStatus @default(ACTIVE)
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  offers WaitlistOffer[]

  @@index([doctorId, status, priority, createdAt])
  @@index([clinicId, status, priority, createdAt])
  @@index([patientId, status])
}

model WaitlistOffer {
  id                  String              @id @default(cuid())
  waitlistEntryId     String
  doctorId            String
  clinicId            String?
  patientId           String
  sourceAppointmentId String?
  slotStartTime       DateTime
  slotEndTime         DateTime
  expiresAt           DateTime
  status              WaitlistOfferStatus @default(SENT)
  acceptedAt          DateTime?
  rejectedAt          DateTime?
  expiredAt           DateTime?
  notifiedChannels    Json?
  metadata            Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  waitlistEntry WaitlistEntry @relation(fields: [waitlistEntryId], references: [id], onDelete: Cascade)
  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sourceAppointment Appointment? @relation("SourceAppointmentWaitlistOffers", fields: [sourceAppointmentId], references: [id], onDelete: SetNull)

  @@index([doctorId, status, expiresAt])
  @@index([waitlistEntryId, createdAt])
  @@index([patientId, status, createdAt])
  @@index([slotStartTime, slotEndTime, status])
}

model AppointmentAuditLog {
  id            String             @id @default(cuid())
  doctorId      String
  appointmentId String?
  patientId     String?
  actorType     AuditActorType
  actorUserId   String?
  source        AuditSource
  action        AuditAction
  fromStatus    AppointmentStatus?
  toStatus      AppointmentStatus?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime           @default(now())

  doctor      User         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient     Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([doctorId, createdAt])
  @@index([appointmentId, createdAt])
  @@index([action, createdAt])
}

model AuditLog {
  id            String   @id @default(cuid())
  doctorId      String?
  appointmentId String?
  patientId     String?
  actorUserId   String?
  action        String
  ipAddress     String?
  userAgent     String?
  metadata      Json?
  createdAt     DateTime @default(now())

  doctor      User?        @relation("UserToAuditLogs", fields: [doctorId], references: [id], onDelete: SetNull)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient     Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([doctorId, createdAt])
  @@index([appointmentId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model Questionnaire {
  id             String   @id @default(cuid())
  appointmentId  String   @unique
  primarySymptom String?
  responses      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Notification {
  id            String              @id @default(cuid())
  appointmentId String
  channel       NotificationChannel
  type          NotificationType
  status        NotificationStatus  @default(PENDING)
  message       String
  externalId    String?
  sentAt        DateTime?
  createdAt     DateTime            @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([appointmentId])
}

model WhatsAppMessageLog {
  id            String                   @id @default(cuid())
  doctorId      String
  appointmentId String?
  patientId     String?
  phone         String
  direction     WhatsAppMessageDirection
  intent        WhatsAppIntent?
  action        WhatsAppMessageAction?
  message       String
  createdAt     DateTime                 @default(now())

  doctor      User         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient     Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([doctorId, createdAt])
  @@index([appointmentId])
  @@index([phone, createdAt])
}

model MedicalRecord {
  id                String   @id @default(cuid())
  patientId         String   @unique
  bloodType         String?
  allergies         String?
  chronicConditions String?
  familyHistory     String?
  updatedAt         DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model ClinicalHistory {
  id             String            @id @default(cuid())
  patientId      String            @unique
  doctorId       String
  payload        Json
  completionPct  Int               @default(0)
  status         ClinicalDocStatus @default(DRAFT)
  lastReviewedAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  patient  Patient                  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  versions ClinicalHistoryVersion[]

  @@index([doctorId])
}

model ClinicalHistoryVersion {
  id                String            @id @default(cuid())
  clinicalHistoryId String
  patientId         String
  doctorId          String
  payload           Json
  completionPct     Int
  status            ClinicalDocStatus
  actorUserId       String?
  createdAt         DateTime          @default(now())

  clinicalHistory ClinicalHistory @relation(fields: [clinicalHistoryId], references: [id], onDelete: Cascade)

  @@index([clinicalHistoryId, createdAt])
  @@index([patientId, createdAt])
}

model EncounterHistory {
  id                         String            @id @default(cuid())
  appointmentId              String            @unique
  clinicalEncounterId        String?           @unique
  patientId                  String
  doctorId                   String
  payload                    Json
  completionPct              Int               @default(0)
  status                     ClinicalDocStatus @default(DRAFT)
  prefilledFromQuestionnaire Boolean           @default(false)
  consultationMode           ConsultationMode  @default(MANUAL)
  aiConsent                  AiConsentState    @default(PENDING)
  aiConsentDecidedAt         DateTime?
  aiConsentActorUserId       String?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt

  appointment Appointment               @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clinicalEncounter ClinicalEncounter?  @relation(fields: [clinicalEncounterId], references: [id], onDelete: SetNull)
  versions    EncounterHistoryVersion[]

  @@index([doctorId])
  @@index([patientId])
}

model ClinicalEncounter {
  id            String                 @id @default(cuid())
  doctorId      String
  patientId     String
  clinicId      String?
  appointmentId String?
  source        ClinicalEncounterSource @default(STANDALONE)
  status        ClinicalEncounterStatus @default(OPEN)
  openedAt      DateTime               @default(now())
  closedAt      DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  doctor          User             @relation("EncounterDoctor", fields: [doctorId], references: [id], onDelete: Cascade)
  patient         Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment     Appointment?     @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  encounterHistory EncounterHistory?
  clinicalNote    ClinicalNote?

  @@index([doctorId, status, createdAt])
  @@index([patientId, status, createdAt])
  @@index([appointmentId])
}

model EncounterHistoryVersion {
  id                 String            @id @default(cuid())
  encounterHistoryId String
  appointmentId      String
  patientId          String
  doctorId           String
  payload            Json
  completionPct      Int
  status             ClinicalDocStatus
  actorUserId        String?
  createdAt          DateTime          @default(now())

  encounterHistory EncounterHistory @relation(fields: [encounterHistoryId], references: [id], onDelete: Cascade)

  @@index([encounterHistoryId, createdAt])
  @@index([appointmentId, createdAt])
}

model ClinicalNote {
  id            String @id @default(cuid())
  appointmentId String? @unique
  clinicalEncounterId String? @unique
  doctorId      String
  patientId     String

  subjective String? @db.Text
  objective  String? @db.Text
  assessment String? @db.Text
  plan       String? @db.Text

  privateNotes String? @db.Text
  soapPayload  Json?

  signatureHash  String?
  signedAt       DateTime?
  signedByUserId String?
  signedSnapshot Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointment   Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clinicalEncounter ClinicalEncounter? @relation(fields: [clinicalEncounterId], references: [id], onDelete: SetNull)
  doctor        User           @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  signedBy      User?          @relation("SignedClinicalNotes", fields: [signedByUserId], references: [id], onDelete: SetNull)
  prescriptions Prescription[]
}

model ConsentCapture {
  id               String      @id @default(cuid())
  appointmentId    String
  doctorId         String
  patientId        String
  capturedByUserId String?
  type             ConsentType
  ipAddress        String?
  userAgent        String?
  metadata         Json?
  createdAt        DateTime    @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor      User        @relation("DoctorConsentCaptures", fields: [doctorId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  capturedBy  User?       @relation("ConsentCapturedByUser", fields: [capturedByUserId], references: [id], onDelete: SetNull)

  @@index([appointmentId, type, createdAt])
  @@index([doctorId, createdAt])
  @@index([patientId, createdAt])
}

model Prescription {
  id             String  @id @default(cuid())
  clinicalNoteId String
  medication     String
  dosage         String
  frequency      String
  duration       String
  instructions   String?

  clinicalNote ClinicalNote @relation(fields: [clinicalNoteId], references: [id], onDelete: Cascade)
}

enum UserRole {
  DOCTOR
  ADMIN
  CLINIC_ADMIN
  PATIENT
  SECRETARY
}

enum AppointmentType {
  NORMAL
  EXTENDED
}

enum AppointmentSource {
  PATIENT
  DOCTOR
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
}

enum AppointmentPaymentStatus {
  NOT_REQUIRED
  PAYMENT_PENDING
  DEPOSIT_PAID
  PAYMENT_FAILED
}

enum DepositRefundMode {
  FULL
  PARTIAL
  CREDIT
  FORFEIT
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum NotificationType {
  CONFIRMATION
  REMINDER
  QUESTIONNAIRE_INVITATION
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum ScheduleBlockType {
  BLOCKED
  PRIVATE_RESERVED
}

enum AuditActorType {
  DOCTOR
  PATIENT
  SYSTEM
  BOT
}

enum AuditSource {
  ADMIN_PANEL
  PUBLIC_BOOKING
  PATIENT_PORTAL
  WHATSAPP_BOT
  AUTOMATION
  SYSTEM
}

enum AuditAction {
  APPOINTMENT_CREATED
  APPOINTMENT_STATUS_CHANGED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_CANCELLED
  APPOINTMENT_MARKED_OVERDUE
  APPOINTMENT_REMINDER_ESCALATED
  APPOINTMENT_AUTO_CLOSED_NO_SHOW
  PATIENT_ASSIGNED_TO_APPOINTMENT
  PATIENT_CREATED_FROM_APPOINTMENT
  CLINICAL_NOTE_UPDATED
  CLINICAL_NOTE_SIGNED
  CLINICAL_HISTORY_UPDATED
  ENCOUNTER_HISTORY_UPDATED
  AI_NOTE_GENERATION_REQUESTED
  AI_NOTE_GENERATION_COMPLETED
  AI_NOTE_GENERATION_FAILED
  CONSENT_CAPTURED
  WAITLIST_OFFER_SENT
  WAITLIST_OFFER_ACCEPTED
  WAITLIST_OFFER_REJECTED
  WAITLIST_OFFER_EXPIRED
  WAITLIST_SLOT_REASSIGNED
}

enum WaitlistEntryStatus {
  ACTIVE
  PAUSED
  BOOKED
  REMOVED
}

enum WaitlistOfferStatus {
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppIntent {
  CONFIRM
  CANCEL
  GREETING
  QUESTION
  UNKNOWN
}

enum WhatsAppMessageAction {
  AUTO_REPLY
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  ALREADY_CONFIRMED
  ALREADY_CANCELLED
  NO_APPOINTMENT
