generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  role         UserRole @default(DOCTOR)
  active       Boolean  @default(true)
  bossId       String?

  // Public Profile Fields
  specialty           String?
  slug                String? @unique
  bio                 String?
  profileImage        String?
  professionalLicense String?
  clinicAddress       String?
  logoImage           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinicId String?

  manager               User?                 @relation("SecretaryManager", fields: [bossId], references: [id], onDelete: SetNull)
  managedUsers          User[]                @relation("SecretaryManager")
  doctorConfig          DoctorConfig?
  subscription          DoctorSubscription?
  onboarding            DoctorOnboarding?
  legalAcceptance       LegalAcceptance?
  blocks                AvailabilityBlock[]
  schedules             ScheduleBlock[]
  appointments          Appointment[]
  clinicalNotes         ClinicalNote[]
  signedClinicalNotes   ClinicalNote[]        @relation("SignedClinicalNotes")
  whatsappMessages      WhatsAppMessageLog[]
  patientAccounts       Patient[]             @relation("PatientAccount")
  directoryPatients     Patient[]             @relation("DoctorPatientDirectory")
  appointmentAuditLogs  AppointmentAuditLog[]
  auditLogs             AuditLog[]            @relation("UserToAuditLogs")
  doctorConsentCaptures ConsentCapture[]      @relation("DoctorConsentCaptures")
  capturedConsentLogs   ConsentCapture[]      @relation("ConsentCapturedByUser")
  aiProcessingJobs      AIProcessingJob[]

  @@index([bossId])
  @@index([clinicId])
}

model DoctorSubscription {
  id                     String    @id @default(cuid())
  doctorId               String    @unique
  status                 String    @default("PENDING")
  provider               String    @default("MOCK")
  planName               String    @default("Plan Mensual")
  amount                 Decimal?  @db.Decimal(10, 2)
  currency               String    @default("MXN")
  customerId             String?
  externalSubscriptionId String?
  externalPriceId        String?
  paymentMethodLast4     String?
  cancelAtPeriodEnd      Boolean   @default(false)
  canceledAt             DateTime?
  lastPaymentAt          DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  features               Json      @default("{}")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([provider, externalSubscriptionId])
  @@index([status, currentPeriodEnd])
}

model DoctorOnboarding {
  id          String    @id @default(cuid())
  doctorId    String    @unique
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model LegalAcceptance {
  id                String   @id @default(cuid())
  userId            String   @unique
  termsVersion      String
  privacyVersion    String
  termsAcceptedAt   DateTime
  privacyAcceptedAt DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentWebhookEvent {
  id              String    @id @default(cuid())
  provider        String
  eventId         String
  eventType       String
  status          String    @default("RECEIVED")
  payload         Json
  processingError String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([provider, eventId])
  @@index([status, createdAt])
}

model DoctorConfig {
  id                                String           @id @default(cuid())
  doctorId                          String           @unique
  consultationDurationMin           Int
  extendedConsultationEnabled       Boolean          @default(true)
  whatsappConnected                 Boolean          @default(false)
  reminderLeadHours                 String?
  reminderWindowMinutes             Int?             @default(15)
  whatsappAutoReplyEnabled          Boolean          @default(true)
  whatsappAutoConfirmEnabled        Boolean          @default(true)
  whatsappAutoCancelEnabled         Boolean          @default(true)
  whatsappBookingMessageTemplate    String?
  whatsappQuestionnaireTemplate     String?
  whatsappReminderPendingTemplate   String?
  whatsappReminderConfirmedTemplate String?
  normalConsultationPrice           Decimal?         @db.Decimal(10, 2)
  extendedConsultationPrice         Decimal?         @db.Decimal(10, 2)
  effectiveFrom                     DateTime?
  preferredConsultationMode         ConsultationMode @default(MANUAL)
  createdAt                         DateTime         @default(now())
  updatedAt                         DateTime         @updatedAt

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Patient {
  id               String         @id @default(cuid())
  userId           String?
  ownerDoctorId    String?
  clinicId         String?
  firstName        String?
  lastNamePaternal String?
  lastNameMaternal String?
  sex              PatientSex?
  gender           PatientGender?
  fullName         String
  dateOfBirth      DateTime       @default(now())
  phone            String
  email            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user                 User?                 @relation("PatientAccount", fields: [userId], references: [id], onDelete: SetNull)
  ownerDoctor          User?                 @relation("DoctorPatientDirectory", fields: [ownerDoctorId], references: [id], onDelete: Cascade)
  appointments         Appointment[]
  medicalRecord        MedicalRecord?
  clinicalHistory      ClinicalHistory?
  clinicalNotes        ClinicalNote[]
  whatsappMessages     WhatsAppMessageLog[]
  appointmentAuditLogs AppointmentAuditLog[]
  auditLogs            AuditLog[]
  consentCaptures      ConsentCapture[]
  contacts             PatientContact[]

  @@index([ownerDoctorId])
  @@index([ownerDoctorId, fullName])
  @@index([clinicId])
}

model PatientContact {
  id               String          @id @default(cuid())
  patientId        String
  relation         PatientRelation
  firstName        String
  lastNamePaternal String
  lastNameMaternal String?
  phone            String
  email            String?
  isPrimary        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([patientId])
  @@index([patientId, isPrimary])
}

model AvailabilityBlock {
  id        String   @id @default(cuid())
  doctorId  String
  date      DateTime
  startTime DateTime
  endTime   DateTime
  isPublic  Boolean  @default(true)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model ScheduleBlock {
  id        String            @id @default(cuid())
  doctorId  String
  date      DateTime
  startTime DateTime
  endTime   DateTime
  reason    String?
  type      ScheduleBlockType
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Appointment {
  id                    String            @id @default(cuid())
  doctorId              String
  patientId             String
  clinicId              String?
  contactId             String?
  date                  DateTime
  startTime             DateTime
  endTime               DateTime
  appointmentType       AppointmentType
  durationMin           Int
  source                AppointmentSource
  status                AppointmentStatus @default(PENDING)
  notes                 String?
  questionnaireAnswered Boolean           @default(false)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  doctor           User                  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient          Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  contact          PatientContact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  questionnaire    Questionnaire?
  notifications    Notification[]
  clinicalNote     ClinicalNote?
  encounterHistory EncounterHistory?
  aiInsight        AIInsight?
  whatsappMessages WhatsAppMessageLog[]
  auditLogs        AppointmentAuditLog[]
  systemAuditLogs  AuditLog[]
  consentCaptures  ConsentCapture[]
  aiProcessingJobs AIProcessingJob[]

  @@index([clinicId])
}

model AppointmentAuditLog {
  id            String             @id @default(cuid())
  doctorId      String
  appointmentId String?
  patientId     String?
  actorType     AuditActorType
  actorUserId   String?
  source        AuditSource
  action        AuditAction
  fromStatus    AppointmentStatus?
  toStatus      AppointmentStatus?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime           @default(now())

  doctor      User         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient     Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([doctorId, createdAt])
  @@index([appointmentId, createdAt])
  @@index([action, createdAt])
}

model AuditLog {
  id            String   @id @default(cuid())
  doctorId      String?
  appointmentId String?
  patientId     String?
  actorUserId   String?
  action        String
  ipAddress     String?
  userAgent     String?
  metadata      Json?
  createdAt     DateTime @default(now())

  doctor      User?        @relation("UserToAuditLogs", fields: [doctorId], references: [id], onDelete: SetNull)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient     Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([doctorId, createdAt])
  @@index([appointmentId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model Questionnaire {
  id             String   @id @default(cuid())
  appointmentId  String   @unique
  primarySymptom String?
  responses      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Notification {
  id            String              @id @default(cuid())
  appointmentId String
  channel       NotificationChannel
  type          NotificationType
  status        NotificationStatus  @default(PENDING)
  message       String
  externalId    String?
  sentAt        DateTime?
  createdAt     DateTime            @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model WhatsAppMessageLog {
  id            String                   @id @default(cuid())
  doctorId      String
  appointmentId String?
  patientId     String?
  phone         String
  direction     WhatsAppMessageDirection
  intent        WhatsAppIntent?
  action        WhatsAppMessageAction?
  message       String
  createdAt     DateTime                 @default(now())

  doctor      User         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient     Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([doctorId, createdAt])
  @@index([appointmentId])
  @@index([phone, createdAt])
}

model MedicalRecord {
  id                String   @id @default(cuid())
  patientId         String   @unique
  bloodType         String?
  allergies         String?
  chronicConditions String?
  familyHistory     String?
  updatedAt         DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model ClinicalHistory {
  id             String            @id @default(cuid())
  patientId      String            @unique
  doctorId       String
  payload        Json
  completionPct  Int               @default(0)
  status         ClinicalDocStatus @default(DRAFT)
  lastReviewedAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  patient  Patient                  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  versions ClinicalHistoryVersion[]

  @@index([doctorId])
}

model ClinicalHistoryVersion {
  id                String            @id @default(cuid())
  clinicalHistoryId String
  patientId         String
  doctorId          String
  payload           Json
  completionPct     Int
  status            ClinicalDocStatus
  actorUserId       String?
  createdAt         DateTime          @default(now())

  clinicalHistory ClinicalHistory @relation(fields: [clinicalHistoryId], references: [id], onDelete: Cascade)

  @@index([clinicalHistoryId, createdAt])
  @@index([patientId, createdAt])
}

model EncounterHistory {
  id                         String            @id @default(cuid())
  appointmentId              String            @unique
  patientId                  String
  doctorId                   String
  payload                    Json
  completionPct              Int               @default(0)
  status                     ClinicalDocStatus @default(DRAFT)
  prefilledFromQuestionnaire Boolean           @default(false)
  consultationMode           ConsultationMode  @default(MANUAL)
  aiConsent                  AiConsentState    @default(PENDING)
  aiConsentDecidedAt         DateTime?
  aiConsentActorUserId       String?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt

  appointment Appointment               @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  versions    EncounterHistoryVersion[]

  @@index([doctorId])
  @@index([patientId])
}

model EncounterHistoryVersion {
  id                 String            @id @default(cuid())
  encounterHistoryId String
  appointmentId      String
  patientId          String
  doctorId           String
  payload            Json
  completionPct      Int
  status             ClinicalDocStatus
  actorUserId        String?
  createdAt          DateTime          @default(now())

  encounterHistory EncounterHistory @relation(fields: [encounterHistoryId], references: [id], onDelete: Cascade)

  @@index([encounterHistoryId, createdAt])
  @@index([appointmentId, createdAt])
}

model ClinicalNote {
  id            String @id @default(cuid())
  appointmentId String @unique
  doctorId      String
  patientId     String

  subjective String? @db.Text
  objective  String? @db.Text
  assessment String? @db.Text
  plan       String? @db.Text

  privateNotes String? @db.Text
  soapPayload  Json?

  signatureHash  String?
  signedAt       DateTime?
  signedByUserId String?
  signedSnapshot Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor        User           @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  signedBy      User?          @relation("SignedClinicalNotes", fields: [signedByUserId], references: [id], onDelete: SetNull)
  prescriptions Prescription[]
}

model ConsentCapture {
  id               String      @id @default(cuid())
  appointmentId    String
  doctorId         String
  patientId        String
  capturedByUserId String?
  type             ConsentType
  ipAddress        String?
  userAgent        String?
  metadata         Json?
  createdAt        DateTime    @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor      User        @relation("DoctorConsentCaptures", fields: [doctorId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  capturedBy  User?       @relation("ConsentCapturedByUser", fields: [capturedByUserId], references: [id], onDelete: SetNull)

  @@index([appointmentId, type, createdAt])
  @@index([doctorId, createdAt])
  @@index([patientId, createdAt])
}

model Prescription {
  id             String  @id @default(cuid())
  clinicalNoteId String
  medication     String
  dosage         String
  frequency      String
  duration       String
  instructions   String?

  clinicalNote ClinicalNote @relation(fields: [clinicalNoteId], references: [id], onDelete: Cascade)
}

enum UserRole {
  DOCTOR
  ADMIN
  PATIENT
  SECRETARY
}

enum AppointmentType {
  NORMAL
  EXTENDED
}

enum AppointmentSource {
  PATIENT
  DOCTOR
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum NotificationType {
  CONFIRMATION
  REMINDER
  QUESTIONNAIRE_INVITATION
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum ScheduleBlockType {
  BLOCKED
  PRIVATE_RESERVED
}

enum AuditActorType {
  DOCTOR
  PATIENT
  SYSTEM
  BOT
}

enum AuditSource {
  ADMIN_PANEL
  PUBLIC_BOOKING
  PATIENT_PORTAL
  WHATSAPP_BOT
  AUTOMATION
  SYSTEM
}

enum AuditAction {
  APPOINTMENT_CREATED
  APPOINTMENT_STATUS_CHANGED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_CANCELLED
  APPOINTMENT_MARKED_OVERDUE
  APPOINTMENT_REMINDER_ESCALATED
  APPOINTMENT_AUTO_CLOSED_NO_SHOW
  PATIENT_ASSIGNED_TO_APPOINTMENT
  PATIENT_CREATED_FROM_APPOINTMENT
  CLINICAL_NOTE_UPDATED
  CLINICAL_NOTE_SIGNED
  CLINICAL_HISTORY_UPDATED
  ENCOUNTER_HISTORY_UPDATED
  AI_NOTE_GENERATION_REQUESTED
  AI_NOTE_GENERATION_COMPLETED
  AI_NOTE_GENERATION_FAILED
  CONSENT_CAPTURED
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppIntent {
  CONFIRM
  CANCEL
  GREETING
  QUESTION
  UNKNOWN
}

enum WhatsAppMessageAction {
  AUTO_REPLY
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  ALREADY_CONFIRMED
  ALREADY_CANCELLED
  NO_APPOINTMENT
  NO_CHANGE
  NOTIFICATION_SENT
}

enum ConsentType {
  BOOKING_PRIVACY_NOTICE
  VERBAL_RECORDING_CONFIRMATION
}

enum ClinicalDocStatus {
  DRAFT
  IN_REVIEW
  FINAL
  SIGNED
}

enum ConsultationMode {
  MANUAL
  AI_DICTATION
  HYBRID
}

enum AiConsentState {
  PENDING
  GRANTED
  DENIED
}

enum AIJobKind {
  SOAP_NOTE_GENERATION
}

enum AIJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum PatientSex {
  MALE
  FEMALE
  INTERSEX
}

enum PatientGender {
  NOT_SPECIFIED
  MASCULINE
  FEMININE
  TRANSGENDER
  TRANSSEXUAL
  TRAVESTI
  INTERSEX
  OTHER
}

enum PatientRelation {
  SELF
  SPOUSE
  PARENT
  CHILD
  SIBLING
  FRIEND
  CAREGIVER
  OTHER
}

model AIInsight {
  id            String @id @default(cuid())
  appointmentId String @unique
  doctorId      String

  diagnoses      Json? // Array of { diagnosis, reasoning }
  treatments     Json? // Array of { treatment, instructions }
  allowedFoods   Json? // Array of strings
  forbiddenFoods Json? // Array of strings

  medicationContext String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model AIProcessingJob {
  id            String      @id @default(cuid())
  appointmentId String
  doctorId      String
  kind          AIJobKind
  status        AIJobStatus @default(QUEUED)
  progressPct   Int         @default(0)
  statusMessage String?
  resultPayload Json?
  errorMessage  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  finishedAt    DateTime?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor      User        @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([appointmentId, kind, createdAt])
  @@index([doctorId, createdAt])
  @@index([status, createdAt])
}
