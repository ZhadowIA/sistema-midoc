# ============================================================
# MiDoc - whatsapp-bot
# Copia este archivo como `.env` y ajusta valores reales.
# ============================================================

# Puerto del bot
PORT=3001

# Endpoint interno del backend principal
APP_WEBHOOK_URL=http://localhost:3000/api/internal/whatsapp/incoming

# Secreto que valida el backend para mensajes entrantes.
# Debe coincidir con WHATSAPP_WEBHOOK_SECRET de consultorio-app/.env
APP_WEBHOOK_SECRET=replace_with_whatsapp_webhook_secret

# Secreto para autenticar llamadas consultorio-app -> bot.
# Debe coincidir con WHATSAPP_BOT_API_SECRET de consultorio-app.
BOT_API_SECRET=replace_with_internal_bot_api_secret_min_16_chars

# Orígenes permitidos para navegador/admin, separados por coma.
# Déjalo vacío solo si el bot queda estrictamente en red interna.
BOT_ALLOWED_ORIGINS=http://localhost:3000
